{
  "name": "european-alternatives",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prepare": "node scripts/install-git-hooks.mjs",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "hooks:install": "node scripts/install-git-hooks.mjs",
    "secrets:scan": "node scripts/scan-secrets.mjs --tracked",
    "secrets:scan:staged": "node scripts/scan-secrets.mjs --staged",
    "test": "vitest run --passWithNoTests",
    "db:import": "php scripts/db-import.php --source tmp/export/catalog.json",
    "db:backup": "bash scripts/db-backup.sh",
    "db:restore": "bash scripts/db-restore.sh"
  },
  "dependencies": {
    "@fontsource/oswald": "^5.2.8",
    "@fontsource/roboto": "^5.2.10",
    "flag-icons": "^7.5.0",
    "framer-motion": "^12.38.0",
    "i18next": "^25.8.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^16.5.4",
    "react-router-dom": "^7.15.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@php-wasm/node": "3.1.25",
    "@php-wasm/universal": "3.1.25",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
